{
	"name": "jadou",
	"version": "1.0.0",
	"description": "In-context Japanese language toolbox.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"Japanese",
		"dictionary",
		"morphological analysis",
		"furigana"
	],
	"author": "Peter Yanase",
	"license": "PolyForm Perimeter v1.0.1",
	"devDependencies": {
		"@types/node": "25.3.5",
		"@eslint/js": "9.30.1",
		"esbuild": "0.27.3",
		"globals": "17.4.0",
		"jiti": "2.6.1",
		"tslib": "2.8.1",
		"typescript": "5.9.3",
		"typescript-eslint": "8.56.1",
		"builtin-modules": "5.0.0"
	},
	"dependencies": {
		"obsidian": "latest",
		"esbuild-plugin-inline-worker": "0.1.1",
		"@patdx/kuromoji": "1.0.4"
	}
}
