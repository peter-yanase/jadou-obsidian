{
	"name": "jadou",
	"version": "1.0.4",
	"description": "In-context Japanese language toolbox.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"Japanese",
		"dictionary",
		"morphological analysis",
		"furigana",
		"sentence segmenting"
	],
	"author": "Peter Yanase",
	"license": "PolyForm Perimeter v1.0.1",
	"devDependencies": {
		"@types/node":"25.6.0",
		"@eslint/js":"10.0.1",
		"esbuild":"0.28.0",
		"globals":"17.6.0",
		"jiti":"2.6.1",
		"tslib":"2.8.1",
		"typescript":"6.0.3",
		"typescript-eslint":"8.59.2",
		"builtin-modules":"5.1.0",
		"eslint-plugin-obsidianmd":"0.2.9",
		"esbuild-plugin-inline-worker":"0.1.1",
		"@patdx/kuromoji":"1.0.4"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
